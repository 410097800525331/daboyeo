# DABOYEO environment template
# Copy this file to .env and fill values locally.
# Do not commit real hosts, account IDs, usernames, tokens, keys, passwords, or private key paths.

TIDB_HOST=your-tidb-host
TIDB_PORT=4000
TIDB_USER=your-tidb-user
TIDB_PASSWORD=your-tidb-password
TIDB_DATABASE=your-tidb-database
TIDB_SSL=true

R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_ENDPOINT_URL=https://your-cloudflare-account-id.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://your-r2-public-domain.example

DABOYEO_BACKEND_PORT=5500
DABOYEO_RECOMMEND_PROVIDER=fallback
DABOYEO_FLYWAY_ENABLED=false
DABOYEO_SYNC_PYTHON=python
DABOYEO_SHOWTIME_STARTUP_ENABLED=false
DABOYEO_SHOWTIME_SYNC_CRON="0 0 * * * *"

ORACLE_HOST=your-oracle-vm-public-ip
DABOYEO_AI_BRIDGE_TOKEN=replace-with-a-long-random-token
ORACLE_USER=your-oracle-ssh-user
ORACLE_SSH_KEY_PATH=C:\path\to\oracle-private-key.key
DABOYEO_BRIDGE_SERVER=http://localhost:5500
