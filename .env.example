# 로컬 개발용 환경변수 예시
# 실제 비밀번호, 토큰, API 키는 .env에만 넣고 커밋하지 않는다.

# CGV
CGV_ID=your-cgv-id
CGV_PASSWORD=your-cgv-password

# Lotte Cinema
LOTTE_ID=your-lotte-id
LOTTE_PASSWORD=your-lotte-password

# Megabox
MEGABOX_ID=your-megabox-id
MEGABOX_PASSWORD=your-megabox-password

# TiDB Cloud / MySQL-compatible Python collectors
TIDB_HOST=gateway01.ap-northeast-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your-prefix.root
TIDB_PASSWORD=your-tidb-password
TIDB_DATABASE=daboyeo_dev
TIDB_SSL=true

# Cloudflare R2 raw archive and poster storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=daboyeo-posters
R2_ENDPOINT_URL=https://your-cloudflare-account-id.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://pub-your-r2-dev-domain.r2.dev

# Spring backend
# Spring uses TIDB_* above as the single DB source.
DABOYEO_BACKEND_PORT=5500
DABOYEO_FLYWAY_ENABLED=false
DABOYEO_FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5500,http://127.0.0.1:5500

# Portfolio/public API guard.
# Leave these disabled on Oracle unless a demo operator needs to trigger collection manually.
DABOYEO_ADMIN_TOKEN=replace-with-a-long-random-admin-token
DABOYEO_PUBLIC_COLLECTION_ENABLED=false
DABOYEO_PUBLIC_NEARBY_REFRESH_ENABLED=false
DABOYEO_PUBLIC_SEAT_LAYOUT_ENABLED=false

# Server-side showtime sync. The deployed backend refreshes TiDB hourly.
# CGV stays disabled until the signed API path is fixed.
DABOYEO_SYNC_ENABLED=true
DABOYEO_SHOWTIME_SYNC_ENABLED=true
DABOYEO_SHOWTIME_SYNC_CRON="0 0 * * * *"
DABOYEO_SHOWTIME_STARTUP_ENABLED=true
DABOYEO_SHOWTIME_INCLUDE_CGV=false
DABOYEO_SHOWTIME_DATE_OFFSETS=0,1,2
DABOYEO_SHOWTIME_AUTO_DISCOVERY_ENABLED=true
DABOYEO_SHOWTIME_ENTRY_REFRESH_ENABLED=true
DABOYEO_SHOWTIME_ENTRY_REFRESH_TTL_MINUTES=10
DABOYEO_SHOWTIME_ENTRY_REFRESH_MAX_WAIT_MILLIS=8000
DABOYEO_SHOWTIME_ENTRY_REFRESH_MAX_DATES=1
DABOYEO_SHOWTIME_ENTRY_REFRESH_MAX_SCHEDULES_PER_BUNDLE=40
DABOYEO_SHOWTIME_DISCOVERY_MOVIE_LIMIT=5
DABOYEO_SHOWTIME_DISCOVERY_LOTTE_CINEMA_LIMIT=3
DABOYEO_SHOWTIME_DISCOVERY_LOTTE_MOVIE_TARGET_LIMIT=1
DABOYEO_SHOWTIME_DISCOVERY_LOTTE_TOTAL_TARGET_LIMIT=2
DABOYEO_SHOWTIME_DISCOVERY_MEGABOX_BUNDLE_LIMIT=2

# Recommendation provider routing. Portfolio deploy defaults to free fallback.
DABOYEO_RECOMMEND_PROVIDER=fallback
DABOYEO_RECOMMEND_OPENAI_MODEL=

# Codex bridge recommendation runtime. Use only for local or Oracle demo/video capture.
# Codex stays disabled when DABOYEO_AI_BRIDGE_TOKEN is blank, even if the provider is set to codex.
# For an Oracle demo, put the same token in the server env and the demo machine env, then run the bridge worker only while presenting.
DABOYEO_RECOMMEND_CODEX_MODEL=
DABOYEO_RECOMMEND_CODEX_FAST_MODEL=gpt-5.4-mini
DABOYEO_RECOMMEND_CODEX_PRECISE_MODEL=gpt-5.4
DABOYEO_RECOMMEND_CODEX_FAST_REASONING_EFFORT=
DABOYEO_RECOMMEND_CODEX_PRECISE_REASONING_EFFORT=medium
DABOYEO_RECOMMEND_CODEX_FAST_AI_CANDIDATE_LIMIT=12
DABOYEO_RECOMMEND_CODEX_PRECISE_AI_CANDIDATE_LIMIT=20
DABOYEO_RECOMMEND_CODEX_FAST_MAX_TOKENS=420
DABOYEO_RECOMMEND_CODEX_PRECISE_MAX_TOKENS=900
DABOYEO_AI_BRIDGE_TOKEN=replace-with-a-long-random-token
DABOYEO_AI_BRIDGE_RESULT_TIMEOUT_SECONDS=75
DABOYEO_AI_BRIDGE_HEARTBEAT_TTL_SECONDS=45
DABOYEO_AI_BRIDGE_JOB_TTL_SECONDS=90
DABOYEO_BRIDGE_SERVER=http://127.0.0.1:5500
DABOYEO_BRIDGE_PROVIDERS=codex
DABOYEO_CODEX_COMMAND=codex
DABOYEO_CODEX_CWD=.
DABOYEO_CODEX_MODEL=
DABOYEO_CODEX_REASONING_EFFORT=
DABOYEO_BRIDGE_POLL_INTERVAL=2
DABOYEO_BRIDGE_WORKER_TIMEOUT=70
DABOYEO_RECOMMEND_MIN_START_BUFFER_MINUTES=20
