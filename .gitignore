.env

# Root-level local tool artifacts. Keep these ignored if tools regenerate them.
.codex-backups/
.playwright-cli/
.local/
.vscode/

# Python caches
__pycache__/
collectors/__pycache__/
collectors/*/__pycache__/

# Root Markdown is private by default. Shared docs belong in README.md or docs/**.
# Workspace task boards and run logs stay local; main should only carry deployable source/config/docs.
/*.md
!/README.md
!/AGENTS.md

# Java / Spring
.gradle/
.gradle-runtime/
build/
backend/.gradle/
backend/.gradle-user-home/
backend/.gradle-runtime/
backend/build/
backend/bin/

# Frontend
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Python
.venv/
venv/
*.pyc

# Local database and generated data
db/local/
db/samples/*.json
db/samples/*.csv
*.sqlite
*.sqlite3

# Logs and local runtime output
*.log
logs/
